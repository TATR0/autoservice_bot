# ── Telegram ──────────────────────────────────────────────────────────────────
BOT_TOKEN=1234567890:AAABBBCCC...
BOT_USERNAME=your_bot_username        # без @

# ── WebApp (фронтенд — GitHub Pages / Vercel / Render Static) ─────────────────
WEBAPP_URL=https://your-name.github.io/autoservice
WEBAPP_ORIGIN=https://your-name.github.io   # для CORS в api.py

# ── Supabase PostgreSQL ────────────────────────────────────────────────────────
# Берётся из: Supabase → Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres

# ── Misc ──────────────────────────────────────────────────────────────────────
MASTER_CHAT_ID=0   # ID чата/канала для «потерянных» заявок (опционально)
